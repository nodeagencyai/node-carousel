{
  "brand": {
    "name": "Node",
    "handle": "@nodeagency",
    "tone": "direct, builder-voice, no fluff"
  },
  "visual": {
    "colors": {
      "background": "#0f0f0f",
      "text": "#FFFFFF",
      "accent": "#29F2FE",
      "accentSecondary": "#0B8AEE",
      "muted": "#555555"
    },
    "fonts": {
      "display": "JetBrains Mono",
      "body": "Inter"
    },
    "background": {
      "type": "noise-gradient",
      "color": "#0f0f0f",
      "noiseGradient": {
        "from": "#0f0f0f",
        "to": "#1a2a3e",
        "angle": 135,
        "noiseType": "organic",
        "noiseIntensity": 0.2
      },
      "noise": {
        "enabled": true,
        "type": "film",
        "intensity": 0.08,
        "scale": 1.0
      }
    },
    "numbering": {
      "style": "fraction-mono",
      "position": "bottom-right"
    },
    "dimensions": {
      "width": 1080,
      "height": 1350
    }
  }
