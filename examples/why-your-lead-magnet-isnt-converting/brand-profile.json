{
  "brand": {
    "name": "Lift",
    "handle": "@liftstudio",
    "tone": "sharp, opinionated, no-BS"
  },
  "visual": {
    "colors": {
      "background": "#1A0F2E",
      "text": "#FFFAF0",
      "accent": "#FFD23F",
      "accentSecondary": "#C9A030",
      "muted": "#9A9A9A"
    },
    "fonts": {
      "display": "DM Serif Display",
      "body": "Inter"
    },
    "background": {
      "type": "noise-gradient",
      "color": "#1A0F2E",
      "noiseGradient": {
        "from": "#1A0F2E",
        "to": "#6B2D7A",
        "angle": 135,
        "noiseType": "organic",
        "noiseIntensity": 0.22
      },
      "noise": {
        "enabled": true,
        "type": "film",
        "intensity": 0.14,
        "scale": 1.0
      }
    },
    "numbering": {
      "style": "bar",
      "position": "bottom-center"
    },
    "decorations": {
      "cornerMarks": false,
      "accentRule": true,
      "numberBadges": false,
      "pullQuoteBlock": true,
      "oversizedMark": true
    },
    "dimensions": {
      "width": 1080,
      "height": 1350
    }
  }
}
